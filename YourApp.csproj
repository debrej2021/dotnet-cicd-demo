<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <!-- Change this to match your actual project/DLL name -->
    <AssemblyName>YourApp</AssemblyName>
    <RootNamespace>YourApp</RootNamespace>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Suppress dev certificate warning in Docker -->
    <UserSecretsId>your-project-secrets-id</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <!-- Add your NuGet packages here -->
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="8.0.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.5.0" />
  </ItemGroup>

</Project>
